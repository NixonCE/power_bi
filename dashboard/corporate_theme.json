{
    "name": "Corporate Enterprise Modern",
    "dataColors": [
        "#1B365D",
        "#008080",
        "#4A777A",
        "#D96B27",
        "#5C6B73",
        "#2E5B88",
        "#8B9B9E",
        "#A85124"
    ],
    "background": "#F4F6F8",
    "foreground": "#1F2937",
    "tableAccent": "#1B365D",
    "visualStyles": {
        "*": {
            "*": {
                "*": [
                    {
                        "fontSize": 10.5,
                        "fontFamily": "Segoe UI",
                        "color": {
                            "solid": {
                                "color": "#1F2937"
                            }
                        }
                    }
                ],
                "background": [
                    {
                        "show": true,
                        "color": {
                            "solid": {
                                "color": "#FFFFFF"
                            }
                        },
                        "transparency": 0
                    }
                ],
                "border": [
                    {
                        "show": true,
                        "color": {
                            "solid": {
                                "color": "#E5E7EB"
                            }
                        },
                        "radius": 4
                    }
                ],
                "dropShadow": [
                    {
                        "show": true,
                        "color": {
                            "solid": {
                                "color": "#000000"
                            }
                        },
                        "position": "Outer",
                        "preset": "Custom",
                        "shadowBlur": 6,
                        "shadowDistance": 2,
                        "shadowAngle": 90,
                        "transparency": 92
                    }
                ],
                "title": [
                    {
                        "show": true,
                        "fontColor": {
                            "solid": {
                                "color": "#111827"
                            }
                        },
                        "fontFamily": "Segoe UI Semibold",
                        "fontSize": 13,
                        "alignment": "Left"
                    }
                ],
                "subtitle": [
                    {
                        "fontColor": {
                            "solid": {
                                "color": "#6B7280"
                            }
                        },
                        "fontFamily": "Segoe UI",
                        "fontSize": 10
                    }
                ],
                "outspacePane": [
                    {
                        "backgroundColor": {
                            "solid": {
                                "color": "#F4F6F8"
                            }
                        }
                    }
                ]
            }
        },
        "page": {
            "*": {
                "background": [
                    {
                        "color": {
                            "solid": {
                                "color": "#F4F6F8"
                            }
                        },
                        "transparency": 0
                    }
                ]
            }
        },
        "actionButton": {
            "*": {
                "border": [
                    {
                        "radius": 6
                    }
                ]
            }
        }
    }
}